# TASE Bot Backend - Environment Variables for GCP Deployment

# MongoDB Atlas
# The Connection string to the GCP-hosted MongoDB Atlas cluster.
MONGO_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="tase_bot_db"

# LLM Keys
# The API key required for the response generator.
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Security (CRITICAL FOR PRODUCTION)
# Use a strong, random 256-bit key for JWT signing
SECRET_KEY="generate-a-secure-random-key-here"

# CORS configuration for Cloud Run
# Comma-separated list of allowed UI domains
ALLOWED_ORIGINS="https://tase-bot-ui-production-url.a.run.app,https://your-custom-domain.com"
